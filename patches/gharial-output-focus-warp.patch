+        assert_eq!(BoolValue::parse("off"), Ok(BoolValue::Off));
+        assert_eq!(BoolValue::parse("toggle"), Ok(BoolValue::Toggle));
+
+        for invalid in ["", "true", "false", "yes", "no", "maybe"] {
+            let error = BoolValue::parse(invalid).unwrap_err();
